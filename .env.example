# Jira API credentials
JIRA_BASE_URL=https://your-instance.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# BigQuery
ENABLE_BIGQUERY_UPLOAD=true
BQ_APPEND_PER_EPIC=true
BQ_CLEAR_TABLE_BEFORE_RUN=true
ALL_EPICS_BIGQUERY_TABLE_ID=your-project.dataset.table

# Output options
SAVE_COMBINED_EXCEL=false
SAVE_PER_EPIC_EXCEL=false

# Performance tuning
EPIC_PARALLEL_WORKERS=4
LLM_PARALLEL_WORKERS=8
JIRA_FETCH_WORKERS=12
LLM_TIMEOUT_SECONDS=75
JIRA_REQUEST_TIMEOUT=30

# Cloud Run HTTP auth (set a strong random string)
# API_SECRET=your-strong-secret-here

# Logging
LOG_LEVEL=INFO
