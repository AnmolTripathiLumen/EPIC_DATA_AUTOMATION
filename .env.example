# Jira Configuration
JIRA_EMAIL=your-email@lumen.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_DOMAIN=lumen.atlassian.net

# GCS Configuration (for Cloud Run deployment)
GCS_BUCKET=your-gcs-bucket-name
GCS_OUTPUT_PREFIX=ctlvs-jira-sync

# Local override (for local development only)
# OUTPUT_FOLDER=C:\Users\your-user\output-folder
